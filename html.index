#34;,&#34;expr&#34;:&#34;var(--app-font-sans)&#34;},{&#34;suffix&#34;:&#34;serif&#34;,&#34;expr&#34;:&#34;var(--app-font-serif)&#34;},{&#34;suffix&#34;:&#34;mono&#34;,&#34;expr&#34;:&#34;var(--app-font-mono)&#34;}],&#34;radius&#34;:[{&#34;suffix&#34;:&#34;sm&#34;,&#34;expr&#34;:&#34;calc(var(--radius) - 4px)&#34;},{&#34;suffix&#34;:&#34;md&#34;,&#34;expr&#34;:&#34;calc(var(--radius) - 2px)&#34;},{&#34;suffix&#34;:&#34;lg&#34;,&#34;expr&#34;:&#34;var(--radius)&#34;},{&#34;suffix&#34;:&#34;xl&#34;,&#34;expr&#34;:&#34;calc(var(--radius) + 4px)&#34;}]};
